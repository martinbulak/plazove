# ── Základná konfigurácia ────────────────────────────────────────────────
# Verejná URL webu (bez lomky na konci). Používa sa v SEO/OG metadátach a sitemap.
NEXT_PUBLIC_SITE_URL=https://aqualandbb.sk

# ── Administrácia ────────────────────────────────────────────────────────
# Heslo do administrácie (/admin). ZMEŇTE pred nasadením!
ADMIN_PASSWORD=zmente-toto-heslo
# Náhodný reťazec na podpis prihlasovacej cookie (min. 32 znakov).
# Vygenerujte napr.:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=zmente-toto-na-nahodny-retazec-aspon-32-znakov

# ── Perzistentné úložisko (POVINNÉ na Verceli) ───────────────────────────
# Na serverless hostingu (Vercel) je súborový systém read-only, preto sa zápisy
# (podpisy výzvy, newsletter, tipy, úpravy obsahu v admine) ukladajú do KV.
# Vytvorte v projekte na Verceli úložisko „KV" (Marketplace → Upstash Redis).
# Vercel automaticky doplní tieto premenné do projektu:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Alternatívne (priamo Upstash):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Ak nie sú nastavené, aplikácia lokálne používa súborový systém (/content).

# ── E-maily (potvrdenie výzvy / newsletter) ──────────────────────────────
# Ak nie je nastavené, potvrdzovací odkaz sa len vypíše do servera (dev režim).
# Pre reálne odosielanie doplňte poskytovateľa (napr. Resend) – viď README.
# RESEND_API_KEY=
# MAIL_FROM=vyzva@aqualandbb.sk
